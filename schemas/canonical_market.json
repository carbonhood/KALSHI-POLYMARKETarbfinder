{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanonicalMarketExtraction",
  "type": "object",
  "required": ["event_type", "event_id", "outcome", "confidence"],
  "additionalProperties": false,
  "properties": {
    "event_type": {
      "type": "string",
      "enum": [
        "central_bank",
        "econ_release",
        "econ_threshold",
        "election",
        "crypto_threshold",
        "sports_pm",
        "legal_outcome",
        "geopolitical",
        "threshold",
        "other"
      ]
    },
    "event_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "description": "Stable snake_case identifier for the underlying event, e.g. federal_reserve_2026_07"
    },
    "entities": {
      "type": "object",
      "additionalProperties": true
    },
    "outcome": {
      "type": "object",
      "required": ["label"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "kind": {
          "type": "string",
          "enum": ["binary", "bucket", "threshold", "team_win", "candidate", "other"]
        }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string", "maxLength": 500 },
        "cutoff": { "type": "string", "maxLength": 40 },
        "source": { "type": "string", "maxLength": 120 }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "resolution_risk_flags": {
      "type": "array",
      "items": { "type": "string", "maxLength": 80 },
      "maxItems": 10
    },
    "evidence": {
      "type": "string",
      "maxLength": 300
    }
  }
}
